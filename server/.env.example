# Course Assignment Module — Backend Environment
# Copy to .env and adjust as needed.

NODE_ENV=development
PORT=4000

# --- Module Database (this module owns this DB only) ---
DB_HOST=localhost
DB_PORT=3307
DB_NAME=course_assignment
DB_USER=ca_user
DB_PASSWORD=ca_password
DB_DIALECT=mysql

# Root creds used by docker-compose to bootstrap MySQL
DB_ROOT_PASSWORD=ca_root_password

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173
